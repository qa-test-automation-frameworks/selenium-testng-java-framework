<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Sauce Demo Accessibility Smoke" parallel="methods" thread-count="1">
    <listeners>
        <listener class-name="io.github.selenium.saucedemo.framework.listener.SuiteConfigurationListener"/>
        <listener class-name="io.github.selenium.saucedemo.framework.listener.AnnotationTransformer"/>
        <listener class-name="io.github.selenium.saucedemo.framework.listener.FrameworkListener"/>
    </listeners>
    <test name="Accessibility Scenarios">
        <classes>
            <class name="io.github.selenium.saucedemo.tests.AccessibilityTests"/>
        </classes>
    </test>
</suite>

