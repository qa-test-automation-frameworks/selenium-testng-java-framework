# Global Execution Configuration
# Credentials intentionally use SCREAMING_SNAKE_CASE so they map directly to environment variables.
# standard_user is the public Sauce Demo demo username, not a private credential.
APP_USERNAME=standard_user
APP_PASSWORD=
browser=CHROME
execution.type=local
headless=false
maximize.window=true
viewport.width=1920
viewport.height=1080
thread.count=1
diagnostics.network.logs.enabled=false
diagnostics.grid.video.base.url=
diagnostics.attach.screenshot.on.failure=true
diagnostics.attach.page.source.on.failure=true
diagnostics.attach.browser.logs.on.failure=true
diagnostics.attach.framework.logs.on.failure=true
diagnostics.sensitive.dom.selectors=input[type='password'], input[name*='password'], input[id*='password'], input[autocomplete='current-password'], input[autocomplete='new-password'], input[type='email'], input[name*='email'], input[id*='email'], input[name*='token'], input[id*='token'], input[name*='secret'], input[id*='secret'], [data-sensitive='true']

# Remote Execution
remote.url=
