[
  {
    "name": "Checkout Validation Defects",
    "messageRegex": ".*Checkout should require.*",
    "matchedStatuses": ["failed"]
  },
  {
    "name": "Authentication Defects",
    "messageRegex": ".*(login error message|Logout should return).*",
    "matchedStatuses": ["failed"]
  },
  {
    "name": "Infrastructure Issues",
    "traceRegex": ".*ConnectException.*|.*WebDriverException.*",
    "matchedStatuses": ["broken"]
  },
  {
    "name": "Synchronization Issues",
    "messageRegex": ".*(ElementClickInterceptedException|StaleElementReferenceException).*",
    "matchedStatuses": ["broken", "failed"]
  },
  {
    "name": "Ignored Tests",
    "matchedStatuses": ["skipped"]
  },
  {
    "name": "Unclassified Failures",
    "matchedStatuses": ["failed", "broken"]
  }
]
