# Copy this file to .env for Docker Compose, or export the values in your shell before local Maven runs.
# Local Maven does not auto-load .env. Do not commit the populated .env file.
APP_USERNAME=standard_user
# Set this locally only. Do not commit a populated value.
APP_PASSWORD=<set-outside-repository>
ENV=qa
BROWSER=CHROME
HEADLESS=true
THREAD_COUNT=1

