<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- thread-count is overridden at runtime by SuiteConfigurationListener from config property thread.count -->
<suite name="Sauce Demo UI Regression" parallel="methods" thread-count="1">
    <listeners>
        <listener class-name="io.github.selenium.saucedemo.framework.listener.SuiteConfigurationListener"/>
        <!-- Suite-level registration keeps retry annotation transformation active before test execution. -->
        <listener class-name="io.github.selenium.saucedemo.framework.listener.AnnotationTransformer"/>
        <listener class-name="io.github.selenium.saucedemo.framework.listener.FrameworkListener"/>
    </listeners>
    <test name="Inventory Scenarios">
        <classes>
            <class name="io.github.selenium.saucedemo.tests.InventoryTests"/>
        </classes>
    </test>
    <test name="Cart Scenarios">
        <classes>
            <class name="io.github.selenium.saucedemo.tests.CartTests"/>
        </classes>
    </test>
    <test name="Checkout Scenarios">
        <classes>
            <class name="io.github.selenium.saucedemo.tests.CheckoutTests"/>
        </classes>
    </test>
    <test name="Login Scenarios">
        <classes>
            <class name="io.github.selenium.saucedemo.tests.LoginTests"/>
        </classes>
    </test>
    <test name="End-to-End Journey Scenarios">
        <classes>
            <class name="io.github.selenium.saucedemo.tests.EndToEndJourneyTests"/>
        </classes>
    </test>
</suite>
